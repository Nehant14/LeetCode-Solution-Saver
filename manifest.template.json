{
  "manifest_version": 3,
  "name": "Retained",
  "version": "1.0.0",
  "description": "Save accepted LeetCode solutions to Google Drive, and restore them on revisit — on your terms, via an explicit Save button.",
  "permissions": ["identity", "activeTab", "clipboardWrite"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "__GOOGLE_OAUTH_CLIENT_ID__",
    "scopes": ["https://www.googleapis.com/auth/drive.file"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Retained — LeetCode to Google Drive",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
